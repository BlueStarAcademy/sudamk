{
  "name": "sudamr-go-app",
  "version": "1.0.0",
  "description": "Go game with KataGo AI",
  "type": "module",
  "main": "server/server.ts",
  "scripts": {
    "start": "npm run start:pair:a",
    "start:pair:a": "concurrently -n client-5173,server-4000 -c cyan,green \"cross-env VITE_API_TARGET=http://localhost:4000 VITE_WS_TARGET=ws://localhost:4000 vite --host --port 5173 --strictPort\" \"cross-env PORT=4000 npm run start-server\"",
    "start:pair:b": "cross-env VITE_API_TARGET=http://localhost:4000 VITE_WS_TARGET=ws://localhost:4000 vite --host --port 5174 --strictPort",
    "start:pair:b:isolated": "concurrently -n client-5174,server-4010 -c magenta,yellow \"cross-env VITE_API_TARGET=http://localhost:4010 VITE_WS_TARGET=ws://localhost:4010 vite --host --port 5174 --strictPort\" \"cross-env PORT=4010 DISABLE_HEALTH_COMPAT_PORT=1 npm run start-server\"",
    "start-client": "vite --host",
    "prestart-server": "node scripts/ensurePrismaGenerate.mjs",
    "start-server": "npx tsx --tsconfig server/tsconfig.json server/server.ts",
    "railway:start": "npm run start-server",
    "build": "npm run build:client",
    "build:client": "vite build",
    "build:server": "echo 'Server build not needed - using tsx for runtime'",
    "prisma:generate": "npx prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "npx prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:db:push": "npx prisma db push --schema prisma/schema.prisma --accept-data-loss",
    "prisma:migrate:resolve": "npx tsx --tsconfig server/tsconfig.json scripts/resolve-failed-migration.ts",
    "prisma:migrate:apply-sql": "npx tsx --tsconfig server/tsconfig.json scripts/apply-migration-sql.ts",
    "prisma:migrate:dev": "npx prisma migrate dev --schema prisma/schema.prisma",
    "deploy:prepare": "npm run prisma:generate",
    "deploy:full": "npm run prisma:generate && npm run prisma:migrate:deploy",
    "migrate": "npx tsx --tsconfig server/tsconfig.json server/migrateFromOldDb.ts",
    "restore-equipment": "npx tsx --tsconfig server/tsconfig.json server/restoreEquipment.ts",
    "force-restore-equipment": "npx tsx --tsconfig server/tsconfig.json server/forceRestoreEquipment.ts",
    "sync-equipment": "npx tsx --tsconfig server/tsconfig.json server/syncEquipmentInventory.ts",
    "emergency-restore-all": "npx tsx --tsconfig server/tsconfig.json server/emergencyRestoreAll.ts",
    "restore-user-from-supabase-backup": "npx tsx --tsconfig server/tsconfig.json server/restoreUserFromSupabaseBackup.ts",
    "migrate:to-railway": "npx tsx --tsconfig server/tsconfig.json scripts/migrate-to-railway.ts",
    "optimize-db": "npx tsx --tsconfig server/tsconfig.json server/scripts/optimizeDatabase.ts",
    "reset-all-guilds": "npx tsx --tsconfig server/tsconfig.json server/scripts/resetAllGuilds.ts",
    "guild-war:match-test": "cross-env GUILD_WAR_MATCH_TEST_MODE=1 npx tsx --tsconfig server/tsconfig.json server/scripts/runGuildWarMatchTest.ts",
    "guild-war:reset-in-progress": "npx tsx --tsconfig server/tsconfig.json server/scripts/resetGuildWarInProgress.ts",
    "guild-war:open-now": "npx tsx --tsconfig server/tsconfig.json server/scripts/openActiveGuildWarsNow.ts",
    "fix-orphaned-guild-refs": "npx tsx --tsconfig server/tsconfig.json server/scripts/fixOrphanedGuildReferences.ts",
    "reset-championship-data": "npx tsx --tsconfig server/tsconfig.json server/scripts/resetAllChampionshipData.ts",
    "reset-championship-scores": "npx tsx --tsconfig server/tsconfig.json server/scripts/resetAllChampionshipScores.ts",
    "reset-ranked-match-stats": "npx tsx --tsconfig server/tsconfig.json server/scripts/resetAllRankedMatchRecords.ts",
    "script:reset-single-tower": "npx tsx --tsconfig server/tsconfig.json server/scripts/resetSinglePlayerAndTower.ts",
    "script:lock-training-quests": "npx tsx --tsconfig server/tsconfig.json server/scripts/lockTrainingQuests.ts",
    "script:send-baduk-school-reset-mail": "npx tsx --tsconfig server/tsconfig.json server/scripts/sendBadukSchoolResetCompensationMail.ts",
    "cleanup-orphaned-games": "npx tsx --tsconfig server/tsconfig.json server/scripts/cleanupOrphanedActiveGames.ts",
    "clean-admin-guild": "npx tsx --tsconfig server/tsconfig.json server/scripts/cleanAdminGuild.ts",
    "script:strip-swiss-league-from-guilds-kv": "npx tsx --tsconfig server/tsconfig.json server/scripts/stripSwissLeagueFromGuildsKv.ts",
    "check-admin-guild": "npx tsx --tsconfig server/tsconfig.json server/scripts/checkAdminGuild.ts",
    "test-db-performance": "npx tsx --tsconfig server/tsconfig.json server/scripts/testDbPerformance.ts",
    "analyze-db-queries": "npx tsx --tsconfig server/tsconfig.json server/scripts/analyzeDbQueries.ts",
    "runscripts": "npx tsx --tsconfig server/tsconfig.json runscripts.ts",
    "optimize-images": "node scripts/optimizeImages.js",
    "compress-images": "npx tsx --tsconfig server/tsconfig.json scripts/compress-images.ts",
    "compress-images:dry": "npx tsx --tsconfig server/tsconfig.json scripts/compress-images.ts --dry-run",
    "sounds:reencode": "node scripts/reencode-sounds.mjs",
    "build:optimized": "npm run optimize-images && vite build",
    "start-frontend": "node scripts/frontendSpaStaticServer.mjs",
    "start-katago": "cross-env PORT=4001 npx tsx --tsconfig server/tsconfig.json server/katagoServer.ts",
    "electron": "electron electron/main.js",
    "electron:dev": "cross-env NODE_ENV=development electron electron/main.js",
    "typecheck:client": "npx tsc --noEmit",
    "typecheck:server": "npx tsc --noEmit -p server/tsconfig.json",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "test": "vitest run",
    "test:unit": "vitest run server/__tests__/unit",
    "test:integration": "vitest run server/__tests__/integration",
    "test:e2e": "playwright test",
    "test:ci": "npm run typecheck && npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.936.0",
    "@prisma/client": "^6.19.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/nodemailer": "^7.0.4",
    "@types/ws": "^8.18.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "prisma": "^6.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "tsx": "^4.21.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sqlite3": "^3.1.11",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "ffmpeg-static": "^5.2.0",
    "imagemin": "^9.0.1",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "postcss": "^8.4.39",
    "sharp": "^0.34.5",
    "supertest": "^7.0.0",
    "tailwindcss": "3.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.1"
  }
}
