# 로컬 개발용 .env 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   copy .env.local.example .env
# DATABASE_URL만 빠르게 넣으려면: .\UPDATE_LOCAL_ENV.ps1

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# 필수: DB (로컬 Postgres 또는 Railway 원격)
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway?schema=public
# Railway 예시: postgresql://postgres:PASSWORD@turntable.proxy.rlwy.net:PORT/railway?sslmode=require

# Google OAuth (로컬 redirect URI 등록 필요)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Kakao OAuth (로컬 redirect URI 등록 필요)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/kakao/callback

# 배포 URL 참고용
DEPLOYED_SITE_URL=https://sudam.up.railway.app

# AI — Railway 원격 API (로컬 KataGo/GnuGo 쓰려면 비우기)
KATAGO_API_URL=https://katago-production.up.railway.app/api/katago/analyze
GNUGO_API_URL=https://gnugo-production.up.railway.app/api/gnugo/move

# KataServer HumanSL (선택)
KATA_SERVER_URL=http://211.37.47.91:8000
KATA_SERVER_KEY=

# 길드전 자동 매칭 테스트 (선택)
# GUILD_WAR_AUTO_MATCH_BLUE_STAR=1

# 이메일 (선택, 미설정 시 dev에서 콘솔 출력)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
