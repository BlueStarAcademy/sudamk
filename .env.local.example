# 로컬 실행 시 필수. PostgreSQL 연결 문자열 (없으면 서버는 뜨지만 DB/로그인 불가)
DATABASE_URL="postgresql://user:password@localhost:5432/sudamr"

# Gnugo API (전략바둑 AI, 도전의 탑 20층+)
# 로컬: Railway에 배포한 Gnugo 서비스 URL을 넣으면 전략바둑 AI·도전의탑 고층에서 사용
# 예: https://your-gnugo.up.railway.app/api/gnugo/move
GNUGO_API_URL=https://your-gnugo-service.up.railway.app/api/gnugo/move

# 로컬에서 Gnugo 프로세스 직접 사용 시 (GNUGO_API_URL 비우면 로컬 gnugo 사용)
# GNUGO_PATH=gnugo
# GNUGO_LEVEL=10

# (운영 긴급) adminLogs 기반 인벤 복구 API용. 16자 이상 임의 문자열. Railway API 서비스에만 설정 권장.
# EMERGENCY_RESTORE_INVENTORY_SECRET=

# --- KST 자정(0:00~0:14) 전체 Postgres 덤프 (복구용 롤링 보관) ---
# Railway: Volume을 DAILY_DB_BACKUP_DIR에 마운트하고, 이미지에 pg_dump(Postgres client) 설치 필요.
# DAILY_DB_BACKUP_ENABLED=true
# DAILY_DB_BACKUP_DIR=./data/db-backups
# DAILY_DB_BACKUP_RETENTION_DAYS=2
# DAILY_DB_BACKUP_FILENAME_PREFIX=sudamr-db
# PG_DUMP_PATH=pg_dump
# DAILY_DB_BACKUP_PG_DUMP_EXTRA=
