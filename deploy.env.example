# 공통 환경 변수 예시
NODE_ENV=production

# Database connection (Prisma / Railway PostgreSQL)
# Railway PostgreSQL connection string.
# Example: postgresql://postgres:password@postgres.railway.internal:5432/railway
# Or external: postgresql://postgres:password@postgres-production-xxxx.up.railway.app:5432/railway
DATABASE_URL=

# KataGo 설정
# 배포 환경에서는 KataGo를 별도 서비스로 운영하는 것을 권장합니다.
# 백엔드는 "바둑 종료 후 계가(스코어링)" 시점에만 KataGo HTTP API를 호출합니다.
# 예: https://<your-katago-service>.up.railway.app/api/katago/analyze
KATAGO_API_URL=

# GnuGo 설정
# AI봇과의 대결(PvE)에서만 사용됩니다. (goAiBot이 GnuGo를 우선 사용, 실패 시 자체 AI로 fallback)
# 예: https://<your-gnugo-service>.up.railway.app/api/gnugo/move
GNUGO_API_URL=

# GnuGo 전용 서버(컨테이너)에서만 사용 가능: 9x9 등 보드 크기 전달(boardsize) 및 타임아웃
# GNUGO_PLAY_TIMEOUT_MS=6000
# GNUGO_GENMOVE_TIMEOUT_MS=20000

# KataGo 로컬 프로세스 설정 (KATAGO_API_URL이 없을 때만 사용)
# docker-compose에서 override 가능
KATAGO_NUM_ANALYSIS_THREADS=4
KATAGO_NUM_SEARCH_THREADS=8
KATAGO_MAX_VISITS=500
KATAGO_NN_MAX_BATCH_SIZE=8

# 계가(스코어링) 전용 한도 — 설정 시 계가 시에만 적용되어 분석 시간 단축 (예: 8~12초대)
# 적용 후 몇 판 정도 승자·점수 일치 여부 확인 권장
# KATAGO_SCORING_MAX_VISITS=300
# KATAGO_SCORING_MAX_TIME_SEC=10

# 이메일 서비스 설정 (AWS SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=noreply@yourdomain.com

# SMTP 설정 (개발 환경용, AWS SES 대신 사용 가능)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# 카카오 로그인 설정
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://yourdomain.com/auth/kakao/callback

# 프론트엔드 URL (이메일 링크용)
FRONTEND_URL=https://yourdomain.com

# 백엔드 CORS: 프론트가 여러 도메인일 때 콤마로 추가 (선택)
# 예: https://app.example.com,https://preview-xxx.up.railway.app
# CORS_ALLOWED_ORIGINS=


